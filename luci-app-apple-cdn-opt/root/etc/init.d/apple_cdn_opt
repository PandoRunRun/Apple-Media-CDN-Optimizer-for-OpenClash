#!/bin/sh /etc/rc.common

START=95
USE_PROCD=1

start_service() {
	# Ensure the hosts file exists
	touch /etc/apple_cdn_opt.hosts

	# Register the hosts file in dnsmasq
	local has_host
	has_host=$(uci -q get dhcp.@dnsmasq[0].addnhosts | grep "/etc/apple_cdn_opt.hosts")
	if [ -z "$has_host" ]; then
		uci add_list dhcp.@dnsmasq[0].addnhosts="/etc/apple_cdn_opt.hosts"
		uci commit dhcp
		/etc/init.d/dnsmasq reload >/dev/null 2>&1
	fi

	# Load config
	local enabled cron_time
	enabled=$(uci -q get apple_cdn_opt.@global[0].enabled)
	cron_time=$(uci -q get apple_cdn_opt.@global[0].cron_time)

	# Clean existing crontab entry
	sed -i '/apple-cdn-opt.sh/d' /etc/crontabs/root 2>/dev/null

	# If enabled, add to crontab
	if [ "$enabled" = "1" ]; then
		local cron_val
		case "$cron_time" in
			"hour") cron_val="0 */1 * * *" ;;
			"3hours") cron_val="0 */3 * * *" ;;
			"6hours") cron_val="0 */6 * * *" ;;
			"12hours") cron_val="0 */12 * * *" ;;
			"day") cron_val="0 0 * * *" ;;
			*) cron_val="0 */6 * * *" ;;
		esac
		echo "$cron_val /usr/share/apple-cdn-opt/apple-cdn-opt.sh run >/dev/null 2>&1" >> /etc/crontabs/root
	fi

	# Restart cron daemon to apply
	/etc/init.d/cron restart >/dev/null 2>&1 || /etc/init.d/cron reload >/dev/null 2>&1
}

stop_service() {
	# Remove crontab entry
	sed -i '/apple-cdn-opt.sh/d' /etc/crontabs/root 2>/dev/null
	/etc/init.d/cron restart >/dev/null 2>&1 || /etc/init.d/cron reload >/dev/null 2>&1

	# Note: We keep the hosts registration in dnsmasq but we empty the hosts file
	# to deactivate the overrides.
	> /etc/apple_cdn_opt.hosts
	
	# Clean system /etc/hosts overrides as well
	sed -i '/# APPLE-CDN-OPT-START/,/# APPLE-CDN-OPT-END/d' /etc/hosts
	
	# Clean OpenClash custom hosts as well
	sed -i '/# APPLE-CDN-OPT-START/,/# APPLE-CDN-OPT-END/d' /etc/openclash/custom/openclash_custom_hosts.list 2>/dev/null
	
	# Clean OpenClash subscription overwrite module as well
	rm -f /www/apple_cdn_opt_module.yaml
	
	/etc/init.d/dnsmasq reload >/dev/null 2>&1
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger "apple_cdn_opt"
}
